{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Distilllab React",
  "version": "0.1.0",
  "identifier": "com.distilllab.desktop.react",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Distilllab React",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
